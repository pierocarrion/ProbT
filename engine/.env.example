# ─── News source (NewsAPI) ────────────────────────────────────────
# On Cloud Run this value is injected from GCP Secret Manager
# (mounted via `gcloud run deploy --set-secrets="NEWSAPI_KEY=NEWSAPI_KEY:latest"`).
# For local dev, paste a key from https://newsapi.org or leave empty to skip news.
NEWSAPI_KEY=

# ─── Sentiment LLM: Gemini ────────────────────────────────────────
# Option A (local dev): paste a Gemini API key from https://aistudio.google.com/apikey
# On Cloud Run this is also mounted from Secret Manager, but see Option B.
GEMINI_API_KEY=

# Option B (Cloud Run / gcloud): Application Default Credentials — preferred in prod.
# With ADC you leave GEMINI_API_KEY empty and the runtime SA calls Vertex AI directly.
# Local equivalent: run `gcloud auth application-default login` once.
GCLOUD_PROJECT=
GCLOUD_LOCATION=us-central1
